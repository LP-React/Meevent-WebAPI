meta {
  name: Verify Email
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/auth/verify-email?token={{verificationToken}}
  body: none
  auth: none
}

vars:pre-request {
  verificationToken: 37386665-b3db-4a1d-8dac-ac18720a5e8c
}

tests {
  test("Status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("Response confirms verification", function() {
    expect(res.getBody()).to.equal("Cuenta verificada exitosamente");
  });
}
