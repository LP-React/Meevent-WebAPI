meta {
  name: Reset Password
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/auth/reset-password
  body: json
  auth: none
}

body:json {
  {
    "token": "{{resetToken}}",
    "newPassword": "NewPassword@123"
  }
}

vars:pre-request {
  resetToken: 2799a4e9-8e90-40a3-8033-d373df245232
}

tests {
  test("Status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("Response confirms reset", function() {
    expect(res.getBody()).to.be.a("string");
  });
}
